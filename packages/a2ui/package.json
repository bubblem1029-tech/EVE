{
  "name": "@kkeve/a2ui",
  "version": "0.0.2",
  "description": "A2UI spec for keve test platform — shared catalog, types, and schema manager",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./catalog": {
      "default": "./skills/a2ui-catalog.json"
    },
    "./templates": {
      "default": "./skills/a2ui-templates.json"
    }
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
