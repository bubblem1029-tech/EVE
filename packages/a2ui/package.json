    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bubblem1029-tech/EVE.git"
  },
  "dependencies": {
    "ajv": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "^5.0.0"
  },
  "license": "MIT"
}